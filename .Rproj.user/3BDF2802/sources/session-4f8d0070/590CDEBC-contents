## Test Results (8 weeks)

```{r inf2-run, results='asis'}
inf2_features <- infmon2_effector_features()

# participant accounting (unique subjects per maternal arm at 8 weeks / InfMon2)
subj <- data_raw %>%
  dplyr::filter(as.character(visit_name) == INF2_VISIT,
                as.character(arm_name) %in% MATERNAL_ARMS,
                as.character(feature) %in% inf2_features) %>%
  dplyr::distinct(subject_accession, arm_name)
n_TT <- sum(as.character(subj$arm_name) == "TT")
n_TdaP <- sum(as.character(subj$arm_name) == "TdaP")
if (exists("nt_log_manual", mode = "function"))
  nt_log_manual(nt, "8-weeks effectors", "Whole + effector functions", "Overall (all infants)",
                "TdaP vs TT (Wilcoxon, per feature)", n_entered = n_TT + n_TdaP,
                n_used = n_TT + n_TdaP,
                note = sprintf("TT = %d, TdaP = %d subjects; per-feature n in table", n_TT, n_TdaP))

inf2_stats <- infmon2_arm_effect(data_raw, visit = INF2_VISIT, features = inf2_features)

cat(sprintf("**Subjects at 8 weeks:** TT n = %d, TdaP n = %d. ", n_TT, n_TdaP))
cat(sprintf("**%d features tested** (%d whole-bacterium assays + %d effector\u00d7antigen cells); BH within each assay class.\n\n",
            nrow(inf2_stats), sum(inf2_stats$class == "Whole bacterium assays"),
            sum(inf2_stats$class != "Whole bacterium assays")))

print(infmon2_effect_kable(
  inf2_stats,
  caption = "8-week maternal TdaP-vs-TT differences (TT referent). Median = median log10 assay value per arm; HL shift = Hodges\u2013Lehmann location shift (TdaP\u2212TT, log10) with Wilcoxon CI; Fold = 10^(HL) = TdaP/TT ratio on the linear scale; Direction uses the bubble convention; p = Wilcoxon rank-sum (same test as the bubbles); p (BH) = Benjamini\u2013Hochberg within the assay class."))
```

