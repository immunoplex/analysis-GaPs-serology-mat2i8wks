# Stratified by maternal arm (TdaP vs TT)

The combined (pooled) decay results above are retained unchanged. This section ADDS the
per-arm breakdown of the *same* CordBlood → InfMon2 change (Δ = InfMon2 − CordBlood, log10;
negative = decay). Catabolism of passively transferred maternal IgG is a property of the
antibody (subclass / FcRn recycling), not of the vaccine the mother received, so the decay
rate is **expected to be similar across arms** even though the absolute starting (cord)
levels differ. This section checks that directly.

```{r by-arm-setup, include=FALSE}
paired_m <- paired %>% dplyr::filter(arm_name %in% MATERNAL_ARMS)

decay_by_arm <- function(pd) {
  pd %>% dplyr::group_by(feature, antigen, analyte) %>%
    dplyr::summarize(
      n_pair    = dplyr::n(),
      med_cord  = round(stats::median(v_from), 3),
      med_inf   = round(stats::median(v_to), 3),
      med_delta = round(stats::median(delta), 3),
      pct_dec   = round(100 * mean(delta < 0), 1),
      p_sr      = tryCatch(signif(stats::wilcox.test(delta, mu = 0, exact = FALSE)$p.value, 3),
                           error = function(e) NA_real_),
      .groups = "drop") %>%
    dplyr::filter(n_pair >= MIN_PAIRED)
}
decay_all <- dplyr::bind_rows(
  decay_by_arm(paired_m)                                   %>% dplyr::mutate(arm = "Pooled"),
  decay_by_arm(dplyr::filter(paired_m, arm_name == "TdaP")) %>% dplyr::mutate(arm = "TdaP"),
  decay_by_arm(dplyr::filter(paired_m, arm_name == "TT"))   %>% dplyr::mutate(arm = "TT")) %>%
  dplyr::mutate(arm = factor(arm, levels = c("Pooled", "TdaP", "TT")))

fmtd <- function(x) ifelse(is.na(x), "n/a", sprintf("%+.3f", x))
getd <- function(ant, an, a, col) {
  r <- decay_all[decay_all$antigen == ant & decay_all$analyte == an & decay_all$arm == a, ]
  if (nrow(r) == 0) NA_real_ else r[[col]][1]
}
```

