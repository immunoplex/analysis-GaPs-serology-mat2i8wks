## Do maternal/infant factors modify the half-life? (Oguti et al. Figs 3–5)

Oguti et al. tested whether the decay rate is modified by infant **birthweight**, **gestational
age at maternal vaccination**, and **maternal age**, and found no significant effect for any
antigen. The clinical covariates needed to repeat that test are in `clin_assess`
(`birth_weight`, `gestational_age_vaccination`, `maternal_age`), so the same analysis is run
here on the total-IgG decay rate. Each infant's rate uses that infant's exact cord-to-2-month
interval, so the covariate tests ask directly whether the per-infant decay rate depends on the
covariate — exactly Oguti et al.'s question. They are reported from the continuous predictor
(with the same PDF cut-points used only to present grouped half-lives), Bonferroni-adjusted
across the six antigens.

```{r halflife-covariates-setup, include=FALSE}
## Load the clinical covariates the same way the serology data are loaded.
clin <- tryCatch(
  {
    e <- new.env()
    load(find_proj_file("data/clin_assess.RData"), envir = e)
    obj <- if (exists("clin_assess", envir = e)) get("clin_assess", envir = e) else get(ls(e)[1], envir = e)
    as.data.frame(obj)
  },
  error = function(err) NULL)

HAVE_CLIN <- !is.null(clin) &&
  all(c("subject_accession", "birth_weight", "gestational_age_vaccination", "maternal_age") %in% names(clin))

if (HAVE_CLIN) {
  clin_use <- clin[, c("subject_accession", "birth_weight",
                       "gestational_age_vaccination", "maternal_age")]
  clin_use$subject_accession <- as.numeric(clin_use$subject_accession)

  ## PDF cut-points (Figs 3–5). Groups with < MIN_PAIRED infants drop out of the fit.
  bw_grp <- function(x) cut(x, breaks = c(-Inf, 3, 3.5, Inf),
                            labels = c("<3 kg", "3 - <3.5 kg", "3.5+ kg"), right = FALSE)
  ga_grp <- function(x) cut(x, breaks = c(-Inf, 27, 32, Inf),
                            labels = c("<27 wk", "27 - <32 wk", "32+ wk"), right = FALSE)
  ma_grp <- function(x) cut(x, breaks = c(-Inf, 25, 30, Inf),
                            labels = c("<25 yr", "25 - <30 yr", "30+ yr"), right = FALSE)

  ## Attach covariates to the per-infant decay-rate frame used for the main table
  ## (hl_use already excludes increases, matching Oguti et al.). Join on a
  ## character key so a numeric/character mismatch in subject_accession cannot
  ## silently drop all matches.
  clin_use$.key <- as.character(clin_use$subject_accession)
  rate_cov <- hl_use
  rate_cov$.key <- as.character(rate_cov$subject_accession)
  rate_cov <- dplyr::left_join(
    rate_cov,
    clin_use[, c(".key", "birth_weight", "gestational_age_vaccination", "maternal_age")],
    by = ".key")

  ## Per-antigen continuous test: is the decay rate modified by the covariate?
  ## (Uses each infant's exact per-day rate; equivalent to Oguti et al.'s test.)
  cov_pval <- function(df, xcol) {
    do.call(rbind, lapply(split(df, df$antigen), function(d) {
      d <- d[is.finite(d$rate) & is.finite(d[[xcol]]), , drop = FALSE]
      if (nrow(d) < 5 || stats::sd(d[[xcol]]) == 0) return(NULL)
      fit <- stats::lm(d$rate ~ d[[xcol]])
      p <- tryCatch(stats::coef(summary(fit))[2, 4], error = function(e) NA_real_)
      data.frame(antigen = d$antigen[1], n = nrow(d), p_raw = p, stringsAsFactors = FALSE)
    }))
  }

  ## Grouped half-lives (presentation only) via the shared fit_one()
  hl_by_group <- function(df, gcol) {
    df <- df[!is.na(df[[gcol]]), , drop = FALSE]
    do.call(rbind, lapply(
      split(df, list(df$antigen, df[[gcol]]), drop = TRUE),
      function(d) {
        f <- fit_one(d); if (is.null(f)) return(NULL)
        cbind(antigen = d$antigen[1], group = as.character(d[[gcol]][1]),
              f, stringsAsFactors = FALSE)
      }))
  }

  rate_cov$bw_g <- bw_grp(rate_cov$birth_weight)
  rate_cov$ga_g <- ga_grp(rate_cov$gestational_age_vaccination)
  rate_cov$ma_g <- ma_grp(rate_cov$maternal_age)

  COV_DEFS <- list(
    list(key = "birth_weight",                label = "Birthweight",                 gcol = "bw_g",
         glevels = c("<3 kg", "3 - <3.5 kg", "3.5+ kg"),          oguti = "no effect (Fig 3)"),
    list(key = "gestational_age_vaccination", label = "Gestational age at vaccination", gcol = "ga_g",
         glevels = c("<27 wk", "27 - <32 wk", "32+ wk"),          oguti = "no effect (Fig 4)"),
    list(key = "maternal_age",                label = "Maternal age",                gcol = "ma_g",
         glevels = c("<25 yr", "25 - <30 yr", "30+ yr"),          oguti = "no effect (Fig 5)"))

  ## Combined per-antigen x covariate p-value table (continuous, Bonferroni)
  cov_p_tab <- do.call(rbind, lapply(COV_DEFS, function(cd) {
    pt <- cov_pval(rate_cov, cd$key)
    if (is.null(pt)) return(NULL)
    pt$covariate <- cd$label
    pt$p_bonf <- pmin(1, pt$p_raw * N_BONF)
    pt
  }))

  n_cov_sig <- if (!is.null(cov_p_tab)) sum(cov_p_tab$p_bonf < 0.05, na.rm = TRUE) else 0L
  n_cov_tests <- if (!is.null(cov_p_tab)) sum(is.finite(cov_p_tab$p_bonf)) else 0L
}
```

```{r halflife-covariates, results='asis'}
if (!HAVE_CLIN) {
  cat("_`clin_assess` (with `birth_weight`, `gestational_age_vaccination`, `maternal_age`) was not ",
      "found next to the serology data, so the covariate comparison was skipped._\n\n")
} else if (is.null(cov_p_tab) || !nrow(cov_p_tab)) {
  cat("_No covariate could be tested (insufficient data after joining `clin_assess`)._\n\n")
} else {
  ## p-value summary: build the wide (antigen x covariate) table manually
  cov_labels <- vapply(COV_DEFS, function(z) z$label, character(1))
  ant_order  <- oguti_ref$antigen[oguti_ref$antigen %in% cov_p_tab$antigen]
  ant_label  <- oguti_ref$antigen_label[match(ant_order, oguti_ref$antigen)]
  disp_p <- data.frame(Antigen = ant_label, check.names = FALSE, stringsAsFactors = FALSE)
  for (cl in cov_labels) {
    vals <- vapply(ant_order, function(a) {
      r <- cov_p_tab$p_bonf[cov_p_tab$antigen == a & cov_p_tab$covariate == cl]
      if (length(r)) signif(r[1], 2) else NA_real_
    }, numeric(1))
    disp_p[[cl]] <- vals
  }
  knitr::kable(disp_p, caption = paste0(
    "Table H5. Bonferroni-adjusted p-values for modification of the total-IgG decay rate by each ",
    "covariate (continuous predictor, one model per antigen), matching Oguti et al. Figs 3–5. Each ",
    "infant's rate uses that infant's exact cord-to-2-month interval. As in the source paper, the ",
    "expectation is that few or none reach significance.")) %>% print()
  cat(sprintf("\nOf **%d** covariate × antigen tests, **%d** are significant after Bonferroni correction. ",
              n_cov_tests, n_cov_sig))
  cat(ifelse(n_cov_sig == 0,
    paste0("This reproduces Oguti et al.: **no measured maternal or infant factor modifies the decay ",
           "rate** of transplacental DTP antibody.\n\n"),
    paste0("Where a test is significant, inspect the grouped half-lives below and treat it cautiously ",
           "given multiple covariates and the observational design.\n\n")))

  ## Grouped half-life tables (one per covariate)
  for (cd in COV_DEFS) {
    gt <- hl_by_group(rate_cov, cd$gcol)
    if (is.null(gt) || !nrow(gt)) {
      cat(sprintf("_No estimable groups for %s._\n\n", cd$label)); next
    }
    gt <- gt %>%
      dplyr::left_join(oguti_ref[, c("antigen", "antigen_label")], by = "antigen") %>%
      dplyr::mutate(group = factor(group, levels = cd$glevels)) %>%
      dplyr::arrange(match(antigen, oguti_ref$antigen), group) %>%
      dplyr::transmute(Antigen = ifelse(is.na(antigen_label), antigen, antigen_label),
                       Group = as.character(group), `N infants` = n,
                       `Half-life (days)` = sprintf("%.1f", half_life),
                       `95% CI` = sprintf("%.1f - %.1f", hl_lo, hl_hi))
    knitr::kable(gt, caption = sprintf(paste0(
      "Table H6. Total-IgG half-life by %s group (PDF cut-points; groups with too few infants are ",
      "omitted). Oguti et al.: %s. Half-lives use each infant's exact cord-to-2-month interval, and ",
      "the *ordering/spread across groups* reflects genuine differences in decay rate."), tolower(cd$label), cd$oguti)) %>% print()
  }
}
