# Interpretation

*All quantities in this section are computed from the current data at knit time (from
`feat_summary`, `analyte_sum`, `decay_all` and the headline diagnostics). Nothing is
hardcoded, so the narrative always matches the tables and figures above.*

This comparison measures **decay of passively transferred maternal antibody** between birth
(`CordBlood`) and the 2-month visit (`InfMon2`), with Δ = InfMon2 − CordBlood (log10). Because
this window precedes the infant's primary immunisation, the infant is not yet producing its
own antigen-specific antibody, so the expected signal is **decay (Δ < 0)** for genuinely
transferred antibody. A positive Δ for a subclass is therefore a flag for a floor or batch
effect rather than true antibody accrual.

```{r interp-calc, include=FALSE}
strongest_decay <- function(an, k = 4) {
  d <- feat_summary %>% dplyr::filter(analyte == an, median_delta < 0) %>%
    dplyr::arrange(median_delta) %>% utils::head(k)
  if (!nrow(d)) return("none")
  paste(sprintf("%s (%+.2f, %.0f%% down)", d$antigen, d$median_delta, d$pct_dec), collapse = "; ")
}
residual_inc <- function(an, k = 4) {
  d <- feat_summary %>% dplyr::filter(analyte == an, median_delta > 0) %>%
    dplyr::arrange(dplyr::desc(median_delta)) %>% utils::head(k)
  if (!nrow(d)) return("none")
  paste(sprintf("%s (%+.2f, %.0f%% up)", d$antigen, d$median_delta, d$pct_inc), collapse = "; ")
}
dec_an <- analyte_sum$analyte[grepl("decreasing", analyte_sum$dominant)]
inc_an <- analyte_sum$analyte[grepl("increasing", analyte_sum$dominant)]
mix_an <- analyte_sum$analyte[analyte_sum$dominant == "mixed"]

ant_decay_phrase <- function(ant) {
  g <- function(an, col) { r <- feat_summary[feat_summary$antigen == ant & feat_summary$analyte == an, ]
    if (nrow(r)) r[[col]][1] else NA_real_ }
  parts <- c()
  if (!is.na(g("IgG",  "median_delta")))
    parts <- c(parts, sprintf("total IgG %+.2f (%.0f%% down)", g("IgG","median_delta"),  g("IgG","pct_dec")))
  if (!is.na(g("IgG1", "median_delta")))
    parts <- c(parts, sprintf("IgG1 %+.2f (%.0f%% down)",       g("IgG1","median_delta"), g("IgG1","pct_dec")))
  if (!length(parts)) return(NA_character_)
  sprintf("**%s** — %s", ant, paste(parts, collapse = "; "))
}
arm_decay <- function(an) {
  ds <- decay_all %>% dplyr::filter(antigen %in% ANTIGEN_ORDER, analyte == an, arm != "Pooled")
  if (!nrow(ds)) return("n/a")
  sprintf("TdaP %s, TT %s",
    fmtd(stats::median(ds$med_delta[ds$arm == "TdaP"], na.rm = TRUE)),
    fmtd(stats::median(ds$med_delta[ds$arm == "TT"],   na.rm = TRUE)))
}
