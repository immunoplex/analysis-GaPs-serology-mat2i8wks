cat("=== c_set / ebaa_extra REFERENCE AUDIT ===\n\n")

for (f in target_files) {
  lines <- tryCatch(readLines(f, warn = FALSE), error = function(e) character(0))
  
  file_hits <- list()
  for (pat in patterns) {
    hits <- which(str_detect(lines, paste0("\\b", pat, "\\b")))
