# ── GaPs Repository Diagnostic Script ─────────────────────────────────────────
# Run from project root: source("gap_diagnostic.R")
# Produces: repo_diagnostic.txt in your working directory

library(fs)
library(dplyr)
library(stringr)

# 1. Full directory tree (excluding .git and data folders)
cat("=== DIRECTORY TREE ===\n")
tree <- dir_tree(
  path = ".",
  recurse = TRUE,
  regexp = "^\\.git$|^data$",  # exclude these
  invert = TRUE
)

# 2. All files with metadata
cat("\n=== FILE INVENTORY ===\n")
all_files <- dir_info(
  path = ".",
  recurse = TRUE,
  regexp = "\\.git",
  invert = TRUE
) %>%
  select(path, type, size, modification_time) %>%
  mutate(
    extension   = path_ext(path),
    filename    = path_file(path),
    directory   = path_dir(path),
    depth       = str_count(path, "/")
  ) %>%
  arrange(directory, filename)

# 3. Summary by extension
cat("\n=== FILES BY TYPE ===\n")
type_summary <- all_files %>%
  filter(type == "file") %>%
  count(extension, sort = TRUE) %>%
  mutate(extension = if_else(extension == "", "[no extension]", extension))

print(type_summary)

# 4. Rmd files specifically — these are the pipeline backbone
cat("\n=== RMD FILES ===\n")
rmd_files <- all_files %>%
  filter(str_detect(extension, regex("rmd", ignore_case = TRUE))) %>%
  select(path, size, modification_time)
print(rmd_files, n = Inf)

# 5. R script files
cat("\n=== R SCRIPTS ===\n")
r_scripts <- all_files %>%
  filter(extension == "R" | extension == "r") %>%
  select(path, size, modification_time)
print(r_scripts, n = Inf)

# 6. HTML output files (to match back to Rmd sources)
cat("\n=== HTML OUTPUTS ===\n")
html_files <- all_files %>%
  filter(extension == "html") %>%
  select(path, size, modification_time)
print(html_files, n = Inf)

# 7. Config and yaml files
cat("\n=== CONFIG / YAML FILES ===\n")
config_files <- all_files %>%
  filter(extension %in% c("yml", "yaml", "json", "toml", "cfg", "ini")) %>%
  select(path, size, modification_time)
print(config_files, n = Inf)

# 8. Data folder summary (structure only, no file listing for privacy)
cat("\n=== DATA FOLDER STRUCTURE (dirs only) ===\n")
if (dir_exists("data")) {
  data_dirs <- dir_info("data", recurse = TRUE) %>%
    filter(type == "directory") %>%
    select(path)
  print(data_dirs)
  
  data_file_types <- dir_info("data", recurse = TRUE) %>%
    filter(type == "file") %>%
    mutate(extension = path_ext(path)) %>%
    count(extension, sort = TRUE)
  cat("\nData file types (no paths):\n")
  print(data_file_types)
}

# 9. Orphaned HTMLs (HTML with no matching Rmd in same dir)
cat("\n=== ORPHANED HTML FILES (no matching Rmd) ===\n")
html_stems <- html_files %>%
  mutate(stem = path_ext_remove(filename), dir = directory)
rmd_stems  <- rmd_files %>%
  mutate(stem = path_ext_remove(filename), dir = directory)
orphaned <- html_stems %>%
  anti_join(rmd_stems, by = c("stem", "dir"))
print(orphaned)

# 10. Rmd files with no matching HTML (not yet rendered)
cat("\n=== UNRENDERED RMD FILES (no matching HTML) ===\n")
unrendered <- rmd_stems %>%
  anti_join(html_stems, by = c("stem", "dir"))
print(unrendered)

# ── Write everything to file ───────────────────────────────────────────────────
sink("repo_diagnostic.txt")
cat("=== GaPs REPO DIAGNOSTIC ===\n")
cat("Generated:", format(Sys.time()), "\n\n")

cat("=== DIRECTORY TREE ===\n")
print(tree)

cat("\n=== FILE INVENTORY ===\n")
print(all_files, n = Inf)

cat("\n=== FILES BY TYPE ===\n")
print(type_summary, n = Inf)

cat("\n=== RMD FILES ===\n")
print(rmd_files, n = Inf)

cat("\n=== R SCRIPTS ===\n")
print(r_scripts, n = Inf)

cat("\n=== HTML OUTPUTS ===\n")
print(html_files, n = Inf)

cat("\n=== CONFIG / YAML FILES ===\n")
print(config_files, n = Inf)

cat("\n=== ORPHANED HTML FILES ===\n")
print(orphaned, n = Inf)

cat("\n=== UNRENDERED RMD FILES ===\n")
print(unrendered, n = Inf)

sink()

cat("\n✓ Diagnostic written to repo_diagnostic.txt\n")
cat("  Please share this file to proceed with refactoring strategy.\n")


