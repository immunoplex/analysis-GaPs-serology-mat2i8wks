# ── Classify code/ files as runtime helpers vs build-once scripts ─────────────
library(fs)
library(stringr)

code_files <- dir_ls("code", regexp = "\\.R$")

# Check if each code/ file is sourced from any analysis Rmd or R helper
analysis_files <- dir_ls(
  c("analysis", "R", "config"),
  recurse = TRUE,
  regexp = "\\.(Rmd|R)$"
)

cat("=== CODE/ FILE CLASSIFICATION ===\n\n")

for (cf in code_files) {
  fname    <- path_file(cf)
  fname_ns <- path_ext_remove(fname)  # without .R
  
  # Search for references to this file across all analysis files
  refs <- character(0)
  for (af in analysis_files) {
    lines <- readLines(af, warn = FALSE)
    hits  <- lines[str_detect(lines, fixed(fname_ns))]
    if (length(hits) > 0) {
      refs <- c(refs, paste0("  ", path_file(af), ": ", trimws(hits)))
    }
  }
  
  if (length(refs) > 0) {
    cat("RUNTIME (sourced during knit):", fname, "\n")
    cat(refs, sep = "\n")
    cat("  → MOVE TO: R/\n\n")
  } else {
    cat("BUILD-ONCE (not sourced in Rmds):", fname, "\n")
    cat("  → KEEP IN: code/\n\n")
  }
}

