# Find all Rmd and R files in analysis/, R/, code/, config/
target_files <- dir_ls(
  path = c("analysis", "R", "code", "config"),
  recurse = TRUE,
  regexp = "\\.(Rmd|R)$"
)

cat("=== PATH UPDATE LOG ===\n\n")
sink("path_update_log.txt")

changes_made <- 0

for (filepath in target_files) {
  lines    <- readLines(filepath, warn = FALSE)
  new_lines <- lines
  
  for (old_pat in names(path_map)) {
    new_pat   <- path_map[old_pat]
    new_lines <- str_replace_all(new_lines, old_pat, new_pat)
  }
  
  if (!identical(lines, new_lines)) {
    # Show what changed
    changed_idx <- which(lines != new_lines)
    cat("FILE:", filepath, "\n")
    for (i in changed_idx) {
      cat("  Line", i, "OLD:", trimws(lines[i]), "\n")
      cat("  Line", i, "NEW:", trimws(new_lines[i]), "\n")
    }
    cat("\n")
    
    # Write back
    writeLines(new_lines, filepath)
    changes_made <- changes_made + 1
  }
}

cat("Total files modified:", changes_made, "\n")
sink()

