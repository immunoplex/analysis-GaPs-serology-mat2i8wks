# ── Content fingerprint comparison ────────────────────────────────────────────
# Run from project root before any git mv operations

library(stringr)

# Files to compare
candidates <- c(
  "PTNA_analysis.Rmd",
  "SBA_analysis.Rmd",
  "WT_IgG_analysis.Rmd"
)

# Files they are suspected to be superseded by
superseding <- c(
  "analysis/predict_M02_PTNA_from_maternal_v2.Rmd",
  "analysis/predict_M02_SBA_from_maternal_v2.Rmd",
  "analysis/predict_M02_WT_IgG_from_maternal_v2.Rmd",
  "concurrent_analysis.Rmd",
  "interaction_and_deming.Rmd"
)

all_files <- c(candidates, superseding)

extract_functions <- function(path) {
  if (!file.exists(path)) return(character(0))
  lines <- readLines(path, warn = FALSE)
  # Extract function calls, chunk labels, data objects loaded
  fns   <- str_extract_all(lines, "[a-zA-Z_.][a-zA-Z0-9_.]*(?=\\()") |> unlist()
  loads <- str_extract_all(lines, "(?<=load\\()['\"]?[^'\"\\)]+") |> unlist()
  reads <- str_extract_all(lines, "(?<=readRDS\\()['\"]?[^'\"\\)]+") |> unlist()
  unique(c(fns, loads, reads))
}

cat("=== CONTENT FINGERPRINTS ===\n\n")
sink("content_comparison.txt")
for (f in all_files) {
  cat("FILE:", f, "\n")
  cat("  Lines:", if (file.exists(f)) length(readLines(f, warn=FALSE)) else "NOT FOUND", "\n")
  cat("  Size: ", if (file.exists(f)) file.size(f) else "N/A", "bytes\n")
  fns <- extract_functions(f)
  cat("  Key calls:", paste(head(fns, 20), collapse=", "), "\n")
  # Show data loads specifically
  if (file.exists(f)) {
    lines <- readLines(f, warn=FALSE)
    data_lines <- lines[str_detect(lines, "load\\(|readRDS\\(|read\\.csv\\(")]
    if (length(data_lines)) {
      cat("  Data loads:\n")
      for (dl in data_lines) cat("   ", trimws(dl), "\n")
    }
    # Show chunk names
    chunks <- lines[str_detect(lines, "^```\\{r")]
    if (length(chunks)) {
      cat("  Chunks:", paste(head(chunks, 8), collapse=" | "), "\n")
    }
  }
  cat("\n")
}
sink()
cat("✓ Written to content_comparison.txt\n")

