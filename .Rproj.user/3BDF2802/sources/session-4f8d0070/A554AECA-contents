# Quantify and characterise the TdaP-vs-TT gap (computed, not asserted).
arm_gap <- function(an) {
  ds <- xfer_all %>% dplyr::filter(antigen %in% ANTIGEN_ORDER, analyte == an, arm != "Pooled")
  td <- stats::median(ds$med_delta[ds$arm == "TdaP"], na.rm = TRUE)
  tt <- stats::median(ds$med_delta[ds$arm == "TT"],   na.rm = TRUE)
  c(tdap = td, tt = tt, gap = td - tt)
}
