# Stratified by maternal arm (TdaP vs TT)

The combined (pooled) transfer results above are retained unchanged. This section ADDS the
per-arm breakdown of the *same* MatBirth → CordBlood transfer (Δ = cord − maternal, log10).
Because placental transfer is a property of the Fc–FcRn interaction rather than of the
vaccine received, the transfer pattern is **expected to be similar across arms** — this
section checks that directly.

```{r by-arm-setup, include=FALSE}
paired_m <- paired %>% dplyr::filter(arm_name %in% MATERNAL_ARMS)

# Per-feature transfer summary for a subject subset, keeping the MatBirth/CordBlood
# level medians so a delta can be read as a cord:maternal relationship.
xfer_by_arm <- function(pd) {
  pd %>% dplyr::group_by(feature, antigen, analyte) %>%
    dplyr::summarize(
      n_pair     = dplyr::n(),
      med_mat    = round(stats::median(v_from), 3),
      med_cord   = round(stats::median(v_to), 3),
      med_delta  = round(stats::median(delta), 3),
      pct_cordhi = round(100 * mean(delta > 0), 1),
      p_sr       = tryCatch(signif(stats::wilcox.test(delta, mu = 0, exact = FALSE)$p.value, 3),
                            error = function(e) NA_real_),
      .groups = "drop") %>%
    dplyr::filter(n_pair >= MIN_PAIRED)
}

xfer_all <- dplyr::bind_rows(
  xfer_by_arm(paired_m)                                   %>% dplyr::mutate(arm = "Pooled"),
  xfer_by_arm(dplyr::filter(paired_m, arm_name == "TdaP")) %>% dplyr::mutate(arm = "TdaP"),
  xfer_by_arm(dplyr::filter(paired_m, arm_name == "TT"))   %>% dplyr::mutate(arm = "TT")) %>%
  dplyr::mutate(arm = factor(arm, levels = c("Pooled", "TdaP", "TT")))

fmtd <- function(x) ifelse(is.na(x), "n/a", sprintf("%+.3f", x))
getx <- function(ant, an, a, col) {
  r <- xfer_all[xfer_all$antigen == ant & xfer_all$analyte == an & xfer_all$arm == a, ]
  if (nrow(r) == 0) NA_real_ else r[[col]][1]
}
