# Interpretation

*All quantities in this section are computed from the current data at knit time (from
`feat_summary`, `analyte_sum`, `xfer_all` and the headline diagnostics). Nothing is
hardcoded, so the narrative always matches the tables and figures above.*

This comparison measures **transplacental transfer**: cord blood (`CordBlood`) versus the
mother at delivery (`MatBirth`), with Δ = cord − maternal (log10). Selective, FcRn-mediated
transfer predicts a split **by IgG subclass rather than by antigen**, with the best-transferred
subclass concentrated above maternal levels and the others arriving at or below.

```{r interp-calc, include=FALSE}
top_xfer <- function(an, k = 4, increasing = TRUE) {
  d <- feat_summary %>% dplyr::filter(analyte == an)
  d <- if (increasing) dplyr::arrange(dplyr::filter(d, median_delta > 0), dplyr::desc(median_delta))
       else            dplyr::arrange(dplyr::filter(d, median_delta < 0), median_delta)
  d <- utils::head(d, k)
  if (!nrow(d)) return("none")
  paste(sprintf("%s (%+.2f, %.0f%% cord>mat)", d$antigen, d$median_delta, d$pct_inc), collapse = "; ")
}
inc_an <- analyte_sum$analyte[grepl("increasing", analyte_sum$dominant)]
dec_an <- analyte_sum$analyte[grepl("decreasing", analyte_sum$dominant)]
mix_an <- analyte_sum$analyte[analyte_sum$dominant == "mixed"]

arm_dir <- summarise_paired(paired_m, by = "arm_name", min_n = MIN_PAIRED) %>%
  dplyr::group_by(arm_name) %>%
  dplyr::summarize(pct = round(100 * mean(direction == "mostly increase"), 1), .groups = "drop")
arm_pct <- function(a) { v <- arm_dir$pct[arm_dir$arm_name == a]; if (length(v)) format(v) else "n/a" }

ant_xfer_phrase <- function(ant) {
  g <- function(an, col) { r <- feat_summary[feat_summary$antigen == ant &
      feat_summary$analyte == an, ]; if (nrow(r)) r[[col]][1] else NA_real_ }
  parts <- c()
  if (!is.na(g("IgG",  "median_delta")))
    parts <- c(parts, sprintf("total IgG %+.2f (%.0f%% cord>mat)", g("IgG","median_delta"),  g("IgG","pct_inc")))
  if (!is.na(g("IgG1", "median_delta")))
    parts <- c(parts, sprintf("IgG1 %+.2f (%.0f%% cord>mat)",       g("IgG1","median_delta"), g("IgG1","pct_inc")))
  if (!length(parts)) return(NA_character_)
  sprintf("**%s** — %s", ant, paste(parts, collapse = "; "))
}

arm_xfer <- function(an) {
  ds <- xfer_all %>% dplyr::filter(antigen %in% ANTIGEN_ORDER, analyte == an, arm != "Pooled")
  if (!nrow(ds)) return("n/a")
  sprintf("TdaP %s, TT %s",
    fmtd(stats::median(ds$med_delta[ds$arm == "TdaP"], na.rm = TRUE)),
    fmtd(stats::median(ds$med_delta[ds$arm == "TT"],   na.rm = TRUE)))
}
